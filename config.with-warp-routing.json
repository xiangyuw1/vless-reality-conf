{
  "inbounds": [
    {
      "listen": "127.0.0.1",
      "port": 7443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "[uuid]",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "sockopt": {
          "acceptProxyProtocol": true
        },
        "realitySettings": {
          "show": false,
          "dest": "www.example.com:443",
          "xver": 0,
          "serverNames": [
            "www.example.com"
          ],
          "privateKey": "[private_key]",
          "shortIds": [
            "[short_id]"
          ]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    },
    {
      "protocol": "wireguard",
      "tag": "warp",
      "settings": {
        "secretKey": "[填入_wgcf_的_PrivateKey]",
        "address": [
          "172.16.0.2/32", 
          "[填入_wgcf_的_IPv6_Address/128]" 
        ],
        "peers": [
          {
            "publicKey": "bmXOC+F1FxEMF9dyiK2H5/1SUtzH0JuVo51h2wPfgyo=",
            "endpoint": "engage.cloudflareclient.com:2408"
            // 如果服务器没有ipv6且发现warp出口站点无法连接，这里可以尝试写成ip：162.159.192.1:2408
          }
        ],
        "mtu": 1280
      }
    },
    {
      "protocol": "blackhole",
      "tag": "blocked"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "outboundTag": "warp",
        "domain": [
          // === AI 平台 ===
          "geosite:openai",
          "geosite:anthropic",
          "domain:claude.ai",
          "domain:anthropic.com",
          // 精准路由 Gemini，不影响 Google 搜索与 YouTube
          "domain:gemini.google.com",
          "domain:bard.google.com",
          "domain:generativelanguage.googleapis.com",
          "domain:ai.google.dev",
          "domain:aistudio.google.com",
          "domain:alkalimakersuite-pa.clients6.google.com",

          // === 常见流媒体 ===
          "geosite:netflix",
          "geosite:disney",
          "geosite:primevideo",
          "geosite:hbo",
          "geosite:hulu",
          "geosite:spotify",
          "geosite:tiktok"
        ]
      },
      {
        "type": "field",
        "outboundTag": "blocked",
        "ip": [
          "geoip:private"
        ]
      }
    ]
  }
}